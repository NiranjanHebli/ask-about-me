# Azure AI Foundry Inference Endpoint Configuration
# This should point to your serverless API or managed endpoint URL (usually ends with /v1 or models.ai.azure.com)
AZURE_FOUNDRY_ENDPOINT=https://<your-model-deployment-endpoint>.models.ai.azure.com

# The API Key associated with your Azure AI Foundry model deployment
AZURE_FOUNDRY_API_KEY=your_azure_foundry_api_key_here

# Optional: The model deployment name (e.g. "gpt-4o", "Llama-3-1-8B-Instruct")
# Some endpoints require specifying a model field in the chat completion request.
AZURE_FOUNDRY_MODEL_NAME=gpt-4o

# Agent Reference Configuration (used by Responses API)
AZURE_FOUNDRY_AGENT_NAME=my-resume-agent
AZURE_FOUNDRY_AGENT_VERSION=2
